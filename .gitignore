# Claude Code — local per-machine settings (permissions allowlist); shared settings.json stays tracked
.claude/settings.local.json

# Sync output — generated build artifact
_sync_drop/

# Dashboard screenshot artifacts — regenerate with scripts/dashboard_screenshot.py
.dashboard_shots/

# design-sync — transient build/verification artifacts.
# Committed: .design-sync/config.json, NOTES.md, conventions.md, previews/, overrides/
.design-sync/sb-reference/
.design-sync/learnings/
.design-sync/.cache/
.design-sync/node_modules
.ds-sync/
ds-bundle/

# deck_sim.py machine-readable dump — regenerate with deck_sim.py --json
sim_results.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Obsidian — workspace state changes on every open/close
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# Excel temp files
~$*.xlsx
~$*.xls

# Scryfall bulk data — large, refresh with scripts/update_scryfall_data.py
collection/oracle-cards.json
collection/rulings.json
