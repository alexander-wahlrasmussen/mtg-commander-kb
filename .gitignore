# Claude Code — local per-machine settings (permissions allowlist); shared settings.json stays tracked
.claude/settings.local.json
# Claude Code — transient agent worktrees (embedded git repos; never commit)
.claude/worktrees/

# Sync output — generated build artifact
_sync_drop/

# Dashboard screenshot artifacts — regenerate with scripts/ui_screenshot.py
.dashboard_shots/

# design-sync — transient build/verification artifacts.
# Committed: .design-sync/config.json, NOTES.md, conventions.md, previews/, overrides/
.design-sync/sb-reference/
.design-sync/learnings/
.design-sync/.cache/
.design-sync/node_modules
.ds-sync/
ds-bundle/

# deck_sim.py machine-readable dump — regenerate with deck_sim.py --json
sim_results.json

# DeckSafe-generated per-deck proxy lists — local "what to proxy to assemble this"
# scratch, not source of truth. Regenerate with the DeckSafe builder.
decks/proxy/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Obsidian — workspace state changes on every open/close
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# Excel temp files
~$*.xlsx
~$*.xls

# Scryfall bulk data — large, refresh with scripts/update_scryfall_data.py
collection/oracle-cards.json
collection/rulings.json
# Scryfall Tagger index — refresh with scripts/update_tag_index.py
collection/oracle-tags.json

# Archidekt raw fetches — regenerate with scripts/fetch_archidekt.py --save
opponents/raw/
