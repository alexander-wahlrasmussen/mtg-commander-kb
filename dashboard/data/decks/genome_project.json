{"slug": "genome_project", "name": "The Genome Project", "commander": "Kuja, Genome Sorcerer", "colors": "Rakdos", "pips": ["B", "R"], "archetype": "Reanimator / combo", "status": "Solid", "bracket": 3, "score": 15, "axes": [{"label": "Core loop", "score": 4}, {"label": "Kill reliability", "score": 4}, {"label": "Durability", "score": 3}, {"label": "Interaction", "score": 4}], "axesTotal": "15/20", "gc": ["Jeska's Will", "Necropotence", "Underworld Breach"], "kicker": "In the Rakdos corner", "corner": "Bracket 3 \u00b7 Rakdos", "tagline": "Trance Kuja + City on Fire (x3 dmg) \u2014 1-2 casts kill the table", "colorLine": "Rakdos \u00b7 BR", "idea": "Kuja builds an army of 0/1 Wizard tokens that ping each opponent for 1 whenever you cast a noncreature spell.", "vitals": [{"label": "Clock", "value": "T8", "accent": true, "sub": "decap T7"}, {"label": "Decap", "value": "T7", "sub": "one opponent"}, {"label": "Game Changers", "value": "3/3", "sub": "bracket-3 cap"}], "briefKillsCaption": "the lines that win", "briefKills": [{"idx": "01", "tag": "combo", "primary": true, "clock": "table T7", "line": "Trance Kuja + City on Fire (\u00d73 all dmg) and/or Harmonic Prodigy / Roaming Throne \u2192 12\u201316+ damage per opponent per spell \u2192 one or two casts kill the table"}, {"idx": "02", "tag": "table", "primary": false, "clock": "table T8", "line": "Trance Kuja + 4 Wizard tokens (Birgi / Storm-Kiln refund the mana) \u2192 8 dmg per opponent per noncreature cast \u2192 ~5 cheap casts"}], "openings": ["Weakest axis \u2014 Durability (3/5): the judges' soft spot.", "Tables (all three) never-close 1% of the time."], "clock": {"decap": "T7", "table": "T8", "grid": [4, 5, 6, 7, 8, 9, 10, 12], "decapCurve": [1, 8, 41, 82, 95, 98, 99, 99], "tableCurve": [0, 2, 18, 49, 78, 93, 97, 99], "never": [0, 1], "src": "lab gp_clock_lab @8k", "sub": "measured kill-clock", "headline": [{"label": "Decap \u00b7 one opp", "value": "T7", "sub": "median kill", "kind": "decap"}, {"label": "Table \u00b7 all three", "value": "T8", "sub": "median kill", "kind": "table"}], "bands": [{"label": "decap", "from": 7, "to": 7, "kind": "decap"}, {"label": "table", "from": 8, "to": 8, "kind": "table"}], "ticks": [4, 6, 8, 10, 12], "axisFrom": 4, "axisTo": 12, "note": "", "noteLabel": "", "caption": "Decap (one opponent) lands around T7; the full table around T8."}, "gamePlan": "Kuja builds an army of 0/1 Wizard tokens that ping each opponent for 1 whenever you cast a noncreature spell. The commander produces one token per end step automatically. Once you control four Wizards (including Kuja), he transforms into Trance Kuja, doubling all Wizard damage. The deck then chains cheap noncreature spells \u2014 draw, rituals, cantrips \u2014 to deal escalating burn damage to the entire table simultaneously.", "winLine": "Trance Kuja + City on Fire (x3 dmg) \u2014 1-2 casts kill the table", "finishers": [{"name": "Wizard Ping Storm", "tag": "primary", "note": "Trance Kuja + 4 Wizard tokens = 8 damage per opponent per noncreature spell."}, {"name": "Multiplier Stack", "tag": "", "note": "Trance Kuja + Harmonic Prodigy (or Roaming Throne) + 3\u20134 Wizard tokens = 12\u201316 damage per spell per opponent."}, {"name": "Bonus Round / Mizzix's Mastery / Underworld Breach Graveyard Storm", "tag": "", "note": "Bonus Round doubles every instant and sorcery for the rest of the turn \u2014 **but its copies are NOT cast** (oracle ruling: the copy \"is created on the stack, so it's not 'cast'\"), so **copies do not trigger Wizard pings**."}, {"name": "Aetherflux Reservoir", "tag": "", "note": "Chain spells to gain escalating life (1st spell = 1 life, 2nd = 2, etc.)."}, {"name": "Exsanguinate", "tag": "", "note": "After generating large mana via Mana Geyser (multiplayer = massive output), Neheb (post-combat mana from ping damage), or Jeska's Will, fire a lethal Exsanguinate at the table."}, {"name": "Peer into the Abyss \u2192 Chain", "tag": "", "note": "Draw half your library."}], "rulings": [{"name": "Kuja is a Wizard", "note": "he counts toward the 4 to flip. So 3 tokens + Kuja = flip."}, {"name": "", "note": "Token pings trigger on cast and resolve before the spell \u2014 the damage happens even if the spell is countered."}, {"name": "", "note": "Trance Kuja's doubling is a replacement effect: doubles all Wizard damage, combat included. It multiplies with City on Fire (\u00d73) and with trigger-doublers."}, {"name": "Harmonic Prodigy / Roaming Throne", "note": "add an extra ping trigger; Trance doubles the damage. Different layers \u2014 they stack multiplicatively."}, {"name": "Black Mage's Rod", "note": "makes a 1/1 Hero token and auto-equips. The equipped creature becomes a Wizard and gains the ping \u2014 the token doesn't count as a Wizard until it's equipped."}, {"name": "Black Waltz No. 3 pings for 2, not 1", "note": "your highest single pinger. Protect it."}, {"name": "Stormsplitter", "note": "tokens are Wizards (count toward the flip) but do not ping \u2014 combat damage only."}, {"name": "Black Market Connections \u2192 \"Hire a Mercenary\"", "note": "= a 3/2 changeling = counts as a Wizard. Use it when you're one short of flipping."}], "composition": [{"name": "Game Changers", "count": 3, "win": false}, {"name": "Wizard Producers / Wizard Synergy", "count": 7, "win": false}, {"name": "Damage Multipliers", "count": 3, "win": false}, {"name": "Mana Engines", "count": 5, "win": false}, {"name": "Spell Multipliers / Replay", "count": 5, "win": false}, {"name": "Burn Finishers", "count": 3, "win": true}, {"name": "Value Creatures", "count": 2, "win": false}, {"name": "Enchantments", "count": 1, "win": false}, {"name": "Card Draw / Selection", "count": 11, "win": false}, {"name": "Commander Protection", "count": 3, "win": false}, {"name": "Interaction", "count": 12, "win": false}, {"name": "Recursion", "count": 1, "win": false}, {"name": "Utility", "count": 1, "win": false}, {"name": "Ramp", "count": 6, "win": false}, {"name": "Lands", "cou