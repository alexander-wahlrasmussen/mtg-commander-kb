ne": [{"label": "Decap \u00b7 one opp", "value": "T9", "sub": "median kill", "kind": "decap"}, {"label": "Table \u00b7 all three", "value": "T9", "sub": "median kill", "kind": "table"}], "bands": [{"label": "decap", "from": 9, "to": 9, "kind": "decap"}, {"label": "table", "from": 9, "to": 9, "kind": "table"}], "ticks": [4, 6, 8, 10, 12], "axisFrom": 4, "axisTo": 12, "note": "", "noteLabel": "", "caption": "Decap (one opponent) lands around T9; the full table around T9."}, "gamePlan": "Go wide cheaply (dorks, Bitterblossom, Saprolings, Hornet Queen), then convert board width into spell discounts and the board+spells into one of three drain engines:", "winLine": "Exquisite Blood + Sanguine Bond loop + any life event (cmdr-indep.)", "finishers": [{"name": "Exquisite Blood loop", "tag": "primary", "note": "Deploy a blood-half (5 MV) and a vito-half (3\u20135 MV), trigger once, table dies at instant speed."}, {"name": "affinity infinite", "tag": "secondary", "note": "Witherbloom + 4+ creatures + **Sprout Swarm** (self-contained) OR **Lab Rats + Phyrexian Altar** \u2192 infinite free casts \u2192 **Witherbloom Apprentice** drains the table."}, {"name": "Razaketh assembly", "tag": "", "note": "8 MV body that turns every token into Vampiric Tutor."}], "rulings": [{"name": "Exquisite Blood + a \"you-gain/opponent-loses\" half loops until someone wins or breaks it", "note": "this is Sanguine Bond's own ruling, not an assumption. One life-gain (or one opponent-life-loss) event seeds the loop; you don't need a payoff turn, just the trigger."}, {"name": "Which half decides table-vs-single", "note": "with a Vito-style \"each opponent loses\" half it's a table kill; with Sanguine Bond (it targets ONE opponent) the loop only drains that one player to death \u2014 re-aim it or run the each-opponent half to actually close the game."}, {"name": "Exquisite Blood can lose YOU the game first", "note": "if you and an opponent lose life simultaneously and it drops you to 0, you lose before its trigger resolves (its own ruling). Watch symmetrical life-loss while the loop is live."}, {"name": "Magecraft triggers on cast OR COPY", "note": "Witherbloom Apprentice (1) and Professor Onyx (2) fire on every copy too, which is exactly what makes the copy loops lethal rather than one-shot."}, {"name": "Chain of Smog goes infinite targeting YOURSELF", "note": "once your hand is empty each copy still triggers magecraft (you \"discard two\" = discard what you can, including zero) and you may keep copying at no further cost, draining 1/2 per copy. Land the Apprentice or Onyx first."}, {"name": "The affinity infinites need the commander", "note": "Witherbloom, the Balancer grants your instants/sorceries affinity for creatures, which zeroes the GENERIC on Sprout Swarm's buyback (convoke taps a creature for the {G}; the Saproling it makes feeds the next cast) and on Lab Rats + Phyrexian Altar (sac the Rat for {B} to recast). Affinity reduces generic mana only \u2014 never the colored pip."}, {"name": "The primary lifeloop is commander-INDEPENDENT", "note": "Exquisite Blood + a vito-half still kills with Witherbloom dead; the affinity infinites are the commander-dependent backup, which is why they come online a turn later and rank as the secondary axis."}], "composition": [{"name": "Drain Payoffs (lifeloop + magecraft)", "count": 9, "win": true}, {"name": "Affinity-Infinite / Magecraft Loop", "count": 3, "win": false}, {"name": "Aristocrats \u2014 Sac Payoffs & Igniters", "count": 5, "win": false}, {"name": "Sacrifice Outlets & Recursion", "count": 6, "win": false}, {"name": "Token Generators / Go-Wide", "count": 5, "win": false}, {"name": "Mana Dorks", "count": 10, "win": false}, {"name": "Mana Rocks & Rituals", "count": 5, "win": false}, {"name": "Tutors", "count": 10, "win": false}, {"name": "Card Advantage / Draw", "count": 4, "win": false}, {"name": "Interaction & Protection", "count": 6, "win": false}, {"name": "Lands", "count": 36, "win": false}], "decklist": {