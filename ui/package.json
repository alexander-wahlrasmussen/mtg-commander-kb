{
  "name": "pod-gauntlet-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React rebuild of the Pod Gauntlet dashboard — the component library is the design system synced to Claude Design.",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "vite build --mode lib",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "storybook": "^8.6.18",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^4.5.4"
  }
}
