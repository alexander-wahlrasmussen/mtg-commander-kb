{
  "name": "pod-gauntlet-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React rebuild of the Pod Gauntlet dashboard — the component library is the design system synced to Claude Design.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
